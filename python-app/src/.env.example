# Configuración de entorno para MVP Packing
# Copia este archivo como .env y completa con tus credenciales reales

# Django
DEBUG=True
SECRET_KEY=your-secret-key-here

# En producción (Render), usar:
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<valor aleatorio seguro — ver render.yaml>
# DJANGO_ALLOWED_HOSTS=tu-servicio.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-servicio.onrender.com

# Backend de persistencia: "sqlite" para desarrollo local, "dataverse" para producción
PERSISTENCE_BACKEND=sqlite

# Dataverse Configuration
DATAVERSE_URL=https://org.api.crm.dynamics.com
DATAVERSE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DATAVERSE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DATAVERSE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
DATAVERSE_API_VERSION=v9.2
DATAVERSE_TIMEOUT=30

# Database (opcional para desarrollo local)
# DATABASE_URL=sqlite:///db.sqlite3
